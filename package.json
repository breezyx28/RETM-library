{
  "name": "retm-library",
  "version": "1.0.0",
  "description": "RETM Library — embeddable React components for visual email template management. Ships <EmailTemplatePanel> (authoring) and <EmailTemplateViewer> (read-only browsing). Tailwind CSS v4 native.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/breezyx28/RETM-library.git"
  },
  "homepage": "https://github.com/breezyx28/RETM-library#readme",
  "bugs": {
    "url": "https://github.com/breezyx28/RETM-library/issues"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./theme.css": "./dist/theme.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "retm-library-spec.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:enforce": "vitest run --coverage --coverage.thresholds.lines=70 --coverage.thresholds.functions=70 --coverage.thresholds.branches=60 --coverage.thresholds.statements=70",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "clean": "rimraf dist",
    "playground": "npm --prefix playground run dev"
  },
  "keywords": [
    "react",
    "email",
    "template",
    "editor",
    "tiptap",
    "email-builder",
    "drag-and-drop",
    "retm-library",
    "retm",
    "tailwindcss"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@tiptap/core": "^2.10.0",
    "@tiptap/extension-color": "^2.27.2",
    "@tiptap/extension-font-family": "^2.27.2",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-text-align": "^2.27.2",
    "@tiptap/extension-text-style": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/pm": "^2.10.0",
    "@tiptap/react": "^2.10.0",
    "@tiptap/starter-kit": "^2.10.0",
    "@tiptap/suggestion": "^2.27.2",
    "clsx": "^2.1.1",
    "he": "^1.2.0",
    "juice": "^11.0.0",
    "lucide-react": "^0.460.0",
    "shiki": "^1.22.0",
    "tailwind-merge": "^2.6.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@tailwindcss/cli": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/he": "^1.2.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^1.6.1",
    "jsdom": "^29.0.2",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18"
  }
}
